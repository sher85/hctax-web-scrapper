{
  "git": {
    "commitMessage": "chore(release): v${version}",
    "requireCleanWorkingDir": true,
    "tagName": "v${version}"
  },
  "github": {
    "release": false
  },
  "hooks": {
    "before:init": "npm run check"
  },
  "npm": {
    "publish": false
  },
  "plugins": {
    "@release-it/conventional-changelog": {
      "header": "# Changelog",
      "infile": "CHANGELOG.md",
      "preset": {
        "name": "conventionalcommits"
      }
    }
  }
}
